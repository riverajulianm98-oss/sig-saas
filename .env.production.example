# ── Application ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://sigcya.com
NEXT_PUBLIC_API_URL=https://api.sigcya.com
NODE_ENV=production

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=sigcya
POSTGRES_USER=sigcya
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME_redis_password@redis:6379/0
REDIS_PASSWORD=CHANGE_ME_redis_password

# ── Auth / JWT ────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_minimum_32_chars_random_string_here
JWT_EXPIRES_IN=7d
NEXTAUTH_SECRET=CHANGE_ME_another_32_chars_random_string
NEXTAUTH_URL=https://sigcya.com

# ── Object Storage (MinIO / S3) ───────────────────────────────────────────────
MINIO_ROOT_USER=CHANGE_ME_admin_user
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_password
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET=sigcya-files
# For AWS S3:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=sigcya-files

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=CHANGE_ME_sendgrid_api_key
SMTP_FROM=noreply@sigcya.com
SMTP_FROM_NAME=SIG CYA

# ── Backup ───────────────────────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=sigcya-backups

# ── Feature flags ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_FEATURE_SSO=false
NEXT_PUBLIC_FEATURE_WEBHOOKS=true
NEXT_PUBLIC_FEATURE_API_ACCESS=true

# ── Monitoring (optional) ─────────────────────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
# DATADOG_API_KEY=
