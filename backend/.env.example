# Application
APP_NAME=SIG SaaS API
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true

# API
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# PostgreSQL
DATABASE_URL=postgresql+psycopg2://sig_user:sig_password@localhost:5432/sig_saas
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_ECHO=false

# Multi-tenant
TENANT_HEADER=X-Tenant-ID
# Require tenant header on protected routes (health/docs are exempt)
TENANT_REQUIRED=false

# JWT (generate: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Storage (local | s3 | minio | r2)
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./storage
STORAGE_PUBLIC_BASE_URL=http://localhost:8000
STORAGE_BUCKET=
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT_URL=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_SIGNED_URL_EXPIRE_SECONDS=3600
MAX_UPLOAD_SIZE_MB=50

# Logging
LOG_LEVEL=INFO
