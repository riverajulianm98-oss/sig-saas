# Application
APP_NAME=SIG SaaS API
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true

# API
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# PostgreSQL
DATABASE_URL=postgresql+psycopg2://sig_user:sig_password@localhost:5432/sig_saas
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_ECHO=false

# Multi-tenant
TENANT_HEADER=X-Tenant-ID
# Require tenant header on protected routes (health/docs are exempt)
TENANT_REQUIRED=false

# JWT (generate: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Logging
LOG_LEVEL=INFO
